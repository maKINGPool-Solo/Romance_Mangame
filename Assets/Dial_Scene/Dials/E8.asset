  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uB179\uC2A4\uC640 \uC5F0\uC544\uAC00 \uB098\uC5D0\uAC8C \uB2E4\uAC00\uC628\uB2E4."
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC788\uC9C0- ..\uC5E5?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uC5F0\uC544..? \uADF8\uB300\uAC00 \uC65C \uC5EC\uAE30\uC5D0...\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC7A0\uAE50\uB9CC..\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC6B0\uB9AC \uB458 \uB2E4 \uACE0\uBC31\uD558\uB7EC \uC628 \uAC70\uC57C?!\""
  - talker: 1
    listener: 0
    face: 0
    text: '"..."'
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uC6B4\uBA85\uC774\uB780.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uCC38\uC73C\uB85C \uC794\uD639\uD558\uAD70.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC88B\uC544!\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uADF8\uB7FC \uC815\uC815\uB2F9\uB2F9\uD558\uAC8C \uC2B9\uBD80 \uBCF4\uC790!\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uBC14\uB77C\uB358 \uBC14\uB2E4.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uD6C4\uD68C \uC5C6\uB294 \uACB0\uD22C\uAC00 \uB418\uACA0\uAD70.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\u300EGOOD END - \uC2B9\uBD80\uB294 \uC9C0\uAE08\uBD80\uD130\u300F"
