  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uB179\uC2A4\uC640 \uC5F0\uC544\uAC00 \uB3D9\uC2DC\uC5D0 \uB0B4 \uC55E\uC73C\uB85C
      \uB2E4\uAC00\uC628\uB2E4."
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC788\uC9C0- ..\uC5E5?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uC5F0\uC544..? \uADF8\uB300\uAC00 \uC65C \uC5EC\uAE30\uC5D0...\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uC124\uB9C8...\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC7A0\uAE50\uB9CC..\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC6B0\uB9AC \uB458 \uB2E4 \uACE0\uBC31\uD558\uB7EC \uC628 \uAC70\uC57C?!\""
  - talker: 1
    listener: 0
    face: 0
    text: '"..."'
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uC6B4\uBA85\uC774\uB780.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uCC38\uC73C\uB85C \uC794\uD639\uD558\uAD70.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"...\uC5D0\uD734.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uADF8\uB7FC \uB09C \uAC08\uB798.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uB098 \uB610\uD55C.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uD328\uBC30\uD55C \uC804\uC7A5\uC5D0 \uBBF8\uB828\uC740 \uB0A8\uAE30\uC9C0
      \uC54A\uB294\uB2E4.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uB450 \uC0AC\uB78C\uC740 \uB098\uB97C \uC2A4\uCCD0 \uC9C0\uB098\uAC00\uBA70
      \uB098\uB780\uD788 \uAC78\uC5B4\uAC14\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uD6C4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uBA40\uB9AC\uC11C \uC5F0\uC544\uC758 \uC6C3\uC74C\uC18C\uB9AC\uC640 \uB179\uC2A4\uC758
      \uD55C\uC228\uC774 \uD568\uAED8 \uB4E4\uB824\uC654\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "...\uC65C \uB458\uC774 \uB354 \uCE5C\uD574\uC9C4 \uAC83 \uAC19\uC9C0?"
  - talker: -1
    listener: 0
    face: 0
    text: "<BAD END - \uACF5\uACF5\uC758 \uC801>"
  choices: []
