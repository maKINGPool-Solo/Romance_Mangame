%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: Dial_1
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: 0
    listener: 0
    face: 0
    text: "\u201C\uADF8\uB54C \uADF8\uAC70\u2026 \uAE30\uC5B5\uD574?\u201D"
  - talker: -1
    listener: 0
    face: 0
    text: "\uD55C\uB098\uAC00 \uC544\uBB34\uB807\uC9C0 \uC54A\uAC8C \uB9D0\uD55C\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uD558\uC9C0\uB9CC \uACF5\uAE30\uAC00 \uC870\uAE08 \uC774\uC0C1\uD558\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uBB34\uC2A8 \uC598\uAE30\uC778\uC9C0 \uBAA8\uB974\uACA0\uB2E4."
  choices:
  - text: "\uAE30\uC5B5\uD558\uB294 \uCC99 \uD55C\uB2E4."
    good:
    - talker: 0
      listener: 0
      face: 2
      text: " \"\uC5ED\uC2DC, \uB108\uB77C\uBA74 \uC78A\uC5C8\uC744 \uB9AC \uC5C6\uB2E4\uACE0
        \uC0DD\uAC01\uD588\uC5B4.\""
    - talker: 0
      listener: 0
      face: 2
      text: "(\uC785\uAC00\uC5D0 \uC7A5\uB09C\uAE30 \uC5B4\uB9B0 \uBBF8\uC18C\uB97C
        \uB760\uBA70) \"\uADF8\uB0A0... \uC6B0\uB9AC\n \uC9C4\uC9DC \uB300\uB2E8\uD588\uC796\uC544.
        \uADF8\uCE58?\""
    bad:
    - talker: 0
      listener: 0
      face: 1
      text: "\"\u2026\uAC70\uC9D3\uB9D0. \uB208\uBE5B\uC774 \uD754\uB4E4\uB9AC\uB294\uB370?
        \uB10C \uC5ED\uC2DC \uB0B4 \uC5F0\uAE30\uB97C \uBABB \uB530\uB77C\uC640.\""
    - talker: 0
      listener: 0
      face: 1
      text: "\"\uADF8\uB7F0 \uC5B4\uC124\uD508 \uAC70\uC9D3\uB9D0\uC740 \uB098\uD55C\uD14C
        \uC548 \uD1B5\uD55C\uB2E4\uB2C8\uAE4C.\""
  - text: "\uC194\uC9C1\uD558\uAC8C \uBAA8\uB978\uB2E4\uACE0 \uD55C\uB2E4"
    good:
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uD478\uD56B, \uBB50\uC57C. \uC194\uC9C1\uD558\uB124? \uADF8\uB7F0
        \uC810\uC740 \uC880 \uADC0\uC5FD\uB2E4\uB2C8\uAE4C.\""
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uC0AC\uC2E4 \uB098\uB3C4 \uC798 \uAE30\uC5B5 \uC548 \uB098\uB294\uB370
        \uADF8\uB0E5 \uCC14\uB7EC\uBCF8 \uAC70\uC57C. \n\uC6B0\uB9AC \uC9C4\uC9DC
        \uBC14\uBCF4 \uAC19\uB2E4.\""
    bad:
    - talker: 0
      listener: 0
      face: 3
      text: "\"\uC78A\uC5C8\uB2E4\uACE0? \uADF8\uB0A0 \uB0B4\uAC00 \uC5BC\uB9C8\uB098\u2026!\""
    - talker: 0
      listener: 0
      face: 3
      text: "\"\uD558, \uB410\uB2E4. \uB108\uB791 \uBB34\uC2A8 \uB9D0\uC744 \uD574.
        \uC815\uB9D0 \uB10C \uB0B4 \uB9C8\uC74C\uC744 \uBAB0\uB77C\uB3C4 \uB108\uBB34
        \uBAB0\uB77C.\""
  - text: "\uD654\uC81C\uB97C \uB3CC\uB9B0\uB2E4"
    good:
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uC544, \uB9DE\uB2E4! \uBC8C\uC368 \uC2DC\uAC04\uC774 \uC774\uB807\uAC8C
        \uB410\uB124?\""
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uADF8\uAC74 \uB098\uC911\uC5D0 \uC598\uAE30\uD558\uACE0, \uC9C0\uAE08
        \uB098\uB791 \uC5B4\uB514 \uC880 \uAC00\uC9C0 \n\uC54A\uC744\uB798? \uC7AC\uBC0C\uB294
        \uACF3 \uC54C\uC544.\""
    bad:
    - talker: 0
      listener: 0
      face: 1
      text: "\"\u2026\uC9C0\uAE08 \uB300\uD654 \uD53C\uD558\uB294 \uAC70\uC57C? \uC0AC\uB78C
        \uC9C4\uC9C0\uD558\uAC8C \uB9CC\uB4DC\uB124.\""
    - talker: 0
      listener: 0
      face: 1
      text: "\"\uB108 \uADF8\uB7F0 \uC2DD\uC73C\uB85C \uB3C4\uB9DD\uCE58\uB294 \uAC70,
        \uC9C4\uC9DC \uC815\uB5A8\uC5B4\uC838.\""
