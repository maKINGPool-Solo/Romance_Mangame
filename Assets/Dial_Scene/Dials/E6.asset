  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: E6
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uD55C\uB098\uC640 \uB179\uC2A4\uAC00 \uB098\uC5D0\uAC8C \uB2E4\uAC00\uC628\uB2E4."
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uB4DC\uB514\uC5B4 \uCC3E\uC558- ...\uC74C?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uBB50\uC57C \uB179\uC2A4! \uB10C \uC5EC\uAE30 \uC65C \uC788\uC5B4?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uB108\uB610\uD55C \uC774 \uC0AC\uB78C\uC5D0\uAC8C \uB9C8\uC74C\uC744
      \uC0AC\uB85C\uC7A1\uD614\uB098.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uC815\uC801\uC774 \uD750\uB978\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uB450 \uC0AC\uB78C\uC758 \uC2DC\uC120\uC774 \uB3D9\uC2DC\uC5D0 \uB098\uB97C
      \uD5A5\uD55C\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"..\uB0B4 \uB9C8\uC74C \uAC00\uC9C0\uACE0 \uC7A5\uB09C\uCE5C\uAC70\uAD6C\uB098..\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uB410\uC5B4.\uB9C8\uC74C\uB300\uB85C \uD574.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uB098\uB294 \uB108\uAC00 \uB0B4 \uAC80\uC774 \uB418\uC5B4\uC904 \uC218
      \uC788\uB2E4\uACE0 \uC0DD\uAC01\uD588\uB294\uB370...\uB10C \uB108\uBB34 \uB9CE\uC740
      \uC190\uC744 \uAC70\uCCE4\uC5B4.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uB108\uB294 \uAC80\uC774 \uC544\uB2C8\uB77C \uAC89\uB9CC \uBC88\uC9C0\uB974\uB974\uD55C
      \uBAA8\uC870\uD488\uC774\uC5C8\uC5B4.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uB458\uC740 \uC11C\uB85C \uD55C \uBC88\uC744 \uBC14\uB77C\uBCF4\uB354\uB2C8,
      \uB9D0\uC5C6\uC774 \uB4F1\uC744 \uB3CC\uB838\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: ...
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uAE50."
  - talker: -1
    listener: 0
    face: 0
    text: "\uC65C \uB458\uC774 \uAC19\uC774 \uAC00\uB294 \uAC70\uC9C0?"
  - talker: -1
    listener: 0
    face: 0
    text: "<BAD END - \uB108 \uBE7C\uACE0 \uD654\uD574>"
  choices: []
