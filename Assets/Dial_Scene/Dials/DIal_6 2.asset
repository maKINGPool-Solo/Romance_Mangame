%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: DIal_6 2
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: 2
    face: 0
    text: "\uC5F0\uC544\uAC00 \uBAB8\uC744 \uCB49 \uB298\uB9AC\uBA70 \uC2A4\uD2B8\uB808\uCE6D\uC744
      \uD558\uACE0 \uC788\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uD314\uC744 \uB3CC\uB9AC\uACE0, \uD5C8\uB9AC\uB97C \uC219\uC774\uACE0,
      \uB2E4\uB9AC\uB97C \uBED7\uB294 \uB3D9\uC791\uC774 \uD558\uB098\uAC19\uC774
      \uC2DC\uC6D0\uC2DC\uC6D0\uD558\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "..\uB108\uBB34 \uC2DC\uC6D0\uD574\uC11C \uC6C0\uC9C1\uC774\uB294 \uB3D9\uC791
      \uD558\uB098\uB9C8\uB2E4 \uAC15\uD48D\uC744 \uC77C\uC73C\uD0A4\uB294 \uB4EF\uD588\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uAC11\uC790\uAE30 \uC5F0\uC544\uC758 \uC790\uC138\uAC00 \uD06C\uAC8C
      \uD754\uB4E4\uB9B0\uB2E4."
  - talker: 2
    listener: 2
    face: 0
    text: "\"...\uC5B4?\""
  - talker: -1
    listener: 2
    face: 0
    text: "\uC5F0\uC544\uAC00 \uD718\uCCAD\uC774\uB2E4 \uADF8\uB300\uB85C \uBC31\uB364\uBE14\uB9C1\uC744
      \uD558\uB4EF \uD55C \uBC14\uD034 \uAD74\uB7EC \uB118\uC5B4\uC84C\uB2E4."
  choices:
  - text: "\"\uAD1C\uCC2E\uC544?\""
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC751! \uD558\uB098\uB3C4 \uC548 \uB2E4\uCCE4\uC5B4!\""
    - talker: 2
      listener: 2
      face: 2
      text: "(\uBC8C\uB5A1 \uC77C\uC5B4\uB098\uBA70)"
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uAC71\uC815\uD574 \uC918\uC11C \uACE0\uB9C8\uC6CC!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC5D0\uC774~ \uBB50 \uC774\uAC74 \uC544\uBB34\uAC83\uB3C4 \uC544\uB2C8\uC9C0..\"(\uBAB8\uC744
        \uD234\uD234 \uD138\uBA74\uC11C)"
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uACA8\uC6B0 \uC774 \uC815\uB3C4\uB85C \uB0B4\uAC00 \uB2E4\uCE60\uAE4C\uBD10?
        \uB098 \uADF8\uB807\uAC8C \uC5F0\uC57D\uD558\uC9C0 \uC54A\uC544.\"\n"
  - text: "\uC5F0\uC544\uB97C \uC77C\uC73C\uCF1C\uC900\uB2E4."
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC624! \uACE0\uB9C8\uC6CC!\""
    - talker: -1
      listener: 2
      face: 2
      text: "(\uC190\uC744 \uB365\uC11D \uC7A1\uACE0 \uBC8C\uB5A1 \uC77C\uC5B4\uB09C\uB2E4.)"
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB2E4\uC74C\uC5D4 \uC548 \uB118\uC5B4\uC9C8\uAC8C! ...\uC544\uB9C8\uB3C4!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC544, \uC7A0\uAE50!\""
    - talker: -1
      listener: 2
      face: 1
      text: "\uC5F0\uC544\uB97C \uC77C\uC73C\uD0A4\uB824\uB294 \uC21C\uAC04, \uADE0\uD615\uC774
        \uBB34\uB108\uC9C4\uB2E4."
    - talker: -1
      listener: 2
      face: 1
      text: "\uB458\uC740 \uADF8\uB300\uB85C \uC5C9\uCF1C \uD55C \uBC14\uD034, \uB450
        \uBC14\uD034 \uB370\uAD74\uB370\uAD74 \uAD74\uB7EC\uBC84\uB838\uB2E4."
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC544\uC624...(\uBA38\uB9AC\uB97C \uB9CC\uC9C0\uBA74\uC11C) \uC774\uBC88
        \uAC74 \uC880 \uC544\uD508\uB370?\u3160\""
  - text: "\"\uC640. \uC2A4\uD2B8\uB808\uCE6D\uC744 \uC5C4\uCCAD \uC2DC\uC6D0\uD558\uAC8C
      \uD558\uB358\uB370?\""
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uADF8\uCE58?!\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uBAB8 \uD478\uB294 \uAC74 \uC81C\uB300\uB85C \uD574\uC57C \uD558\uB2C8\uAE4C!\""
    - talker: -1
      listener: 2
      face: 2
      text: "\uC5F0\uC544\uB294 \uD55C \uBC88 \uB354 \uD314\uC744 \uD798\uCC28\uAC8C
        \uB3CC\uB9B0\uB2E4."
    - talker: -1
      listener: 2
      face: 2
      text: "\uADF8\uB85C \uC778\uD574 \uBC1C\uC0DD\uB418\uB294 \uAC15\uD48D\uC5D0
        \uB098\uB294 \uB0A0\uC544\uAC08 \uBED4\uD55C\uB2E4."
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB098\uC911\uC5D0 \uC2A4\uD2B8\uB808\uCE6D \uAC19\uC774 \uD558\uC790!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"...\uC751?\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"...\uB098 \uB180\uB9B0 \uAC70\uC9C0?\""
    - talker: 2
      listener: 2
      face: 1
      text: "(\uBA38\uB9AC\uB97C \uAE01\uC801\uC774\uBA70 \uBA4B\uCA4D\uAC8C \uC6C3\uB294\uB2E4.)"
    - talker: 2
      listener: 2
      face: 1
      text: "\"...\uC870\uAE08 \uCC3D\uD53C\uD558\uB124.\""
