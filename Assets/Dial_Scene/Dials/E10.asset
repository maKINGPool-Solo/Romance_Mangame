  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uD55C\uB098\uC640 \uC5F0\uC544\uAC00 \uB3D9\uC2DC\uC5D0 \uB0B4 \uC55E\uC73C\uB85C
      \uB2E4\uAC00\uC628\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uC5B4?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uC5F0\uC544?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC557! \uD55C\uB098?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"...\uC65C \uC5EC\uAE30 \uC788\uC5B4?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC124\uB9C8...\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC7A0\uAE50!\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC6B0\uB9AC \uB458 \uB2E4 \uACE0\uBC31\uD558\uB7EC \uC628 \uAC70\uC57C?!\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uC815\uC801\uC774 \uD750\uB978\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uD55C\uB098\uC640 \uC5F0\uC544\uAC00 \uB3D9\uC2DC\uC5D0 \uB098\uB97C
      \uBC14\uB77C\uBCF8\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uB410\uC5B4.\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC774\uC81C \uB9C8\uC74C\uB300\uB85C \uD574.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"...\uC74C.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uD55C\uB098, \uC6B0\uB9AC \uB514\uC800\uD2B8 \uBA39\uC73C\uB7EC \uAC08\uB798?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uC751.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uB458\uC740 \uB098\uB97C \uB4A4\uB85C\uD55C \uCC44 \uB098\uB780\uD788
      \uAC78\uC5B4\uAC14\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: ...
  - talker: -1
    listener: 0
    face: 0
    text: "\uC5B4\uC9F8 \uB458\uC774 \uB354 \uC990\uAC70\uC6CC \uBCF4\uC774\uB294
      \uAC74 \uAE30\uBD84 \uD0D3\uC77C\uAE4C."
  - talker: -1
    listener: 0
    face: 0
    text: "<BAD END - \uB458\uC774 \uB354 \uC798 \uB9DE\uB124>"
  choices: []
