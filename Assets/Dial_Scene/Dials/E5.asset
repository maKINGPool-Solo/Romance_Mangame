  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: E5
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uD55C\uB098\uC640 \uB179\uC2A4\uAC00 \uB098\uC5D0\uAC8C \uB2E4\uAC00\uC628\uB2E4."
  - talker: 1
    listener: 0
    face: 0
    text: "\"\uB4DC\uB514\uC5B4 \uCC3E\uC558- ...\uC74C?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uBB50\uC57C \uB179\uC2A4! \uB10C \uC5EC\uAE30 \uC65C \uC788\uC5B4?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uB108\uB610\uD55C \uC774 \uC0AC\uB78C\uC5D0\uAC8C \uB9C8\uC74C\uC744
      \uC0AC\uB85C\uC7A1\uD614\uB098.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uC815\uC801\uC774 \uD750\uB978\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uB450 \uC0AC\uB78C\uC758 \uC2DC\uC120\uC774 \uB3D9\uC2DC\uC5D0 \uB098\uB97C
      \uD5A5\uD55C\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uD765.\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC774\uBC88\uB9CC\uD07C\uC740 \uC591\uBCF4 \uC548 \uD560 \uAC70\uC57C.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uC88B\uB2E4.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uC815\uC815\uB2F9\uB2F9\uD558\uAC8C \uC2B9\uBD80\uB97C \uBCF4\uC790.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uB458\uC740 \uC11C\uB85C\uB97C \uB178\uB824\uBCF4\uBA74\uC11C\uB3C4,
      \uC774\uC0C1\uD558\uB9AC\uB9CC\uCE58 \uC6C3\uACE0 \uC788\uC5C8\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "...\uC660\uC9C0 \uC55E\uC73C\uB85C\uAC00 \uB354 \uC2DC\uB044\uB7EC\uC6CC\uC9C8
      \uAC83 \uAC19\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "<GOOD END - \uC0BC\uAC01\uAD00\uACC4 \uAC1C\uB9C9.>"
  choices: []
