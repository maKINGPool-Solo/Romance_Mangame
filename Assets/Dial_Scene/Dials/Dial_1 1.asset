%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: Dial_1 1
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: 1
    listener: 1
    face: 0
    text: "\u201C\uADF8\uB54C \uADF8\uAC70\u2026 \uAE30\uC5B5\uD574?\u201D"
  - talker: -1
    listener: 1
    face: 0
    text: "\uB179\uC2A4\uAC00 \uC544\uBB34\uB807\uC9C0 \uC54A\uAC8C \uB9D0\uD55C\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "\uD558\uC9C0\uB9CC \uACF5\uAE30\uAC00 \uC870\uAE08 \uC774\uC0C1\uD558\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "\uBB34\uC2A8 \uC598\uAE30\uC778\uC9C0 \uBAA8\uB974\uACA0\uB2E4."
  choices:
  - text: "\uAE30\uC5B5\uD558\uB294 \uCC99 \uD55C\uB2E4."
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uD6D7, \uC5ED\uC2DC \uB098\uC758 \uC5B4\uB460\uC744 \uACF5\uC720\uD558\uB294
        \uC790\uB2F5\uAD70.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uADF8 \uAE08\uAE30\uB41C \uAE30\uC5B5\uB9C8\uC800 \uB108\uC640 \uD568\uAED8\uB77C\uBA74...
        \uADF8\uAC83 \uB610\uD55C \n\uC6B4\uBA85\uC774\uB77C \uBD80\uB97C \uC218
        \uC788\uACA0\uC9C0.\""
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uAC00\uC99D\uC2A4\uB7FD\uAD70. \uC601\uD63C\uC758 \uC6B8\uB9BC\uC774
        \uB290\uAEF4\uC9C0\uC9C0 \uC54A\uC544.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uB098\uC758 \uAE30\uC5B5\uC744 \uD749\uB0B4 \uB0B4\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4
        \uB108\uB77C\uB294 \uC874\uC7AC\n\uC758 \uC624\uB9CC\uD568\uC774 \uB4DC\uB7EC\uB098\uB294\uAD70.\""
  - text: "\uC194\uC9C1\uD558\uAC8C \uBAA8\uB978\uB2E4\uACE0 \uD55C\uB2E4"
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "\"\u2026\uC194\uC9C1\uD568\uC778\uAC00. \uC624\uB9CC\uD568\uBCF4\uB2E4
        \uB0AB\uAD70.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uADF8\uB798, \uBB34\uC9C0(\u7121\u77E5) \uB610\uD55C \uC6B0\uB9AC\uC758
        \uC6B4\uBA85\uC77C\uC9C0\uB2C8. \uC7A0\uC2DC \uC78A\uD600\uC9C4 \uAE30\uB85D\uC73C\uB85C
        \uB0A8\uACA8\uB450\uB3C4\uB85D \uD558\uC9C0.\""
    bad:
    - talker: 1
      listener: 1
      face: 3
      text: "\"\uAE30\uC5B5\uC870\uCC28 \uD558\uC9C0 \uBABB\uD558\uB294 \uBA4D\uCCAD\uC774\uC5D0\uAC8C
        \uAE30\uB300\uD55C \uB0B4\uAC00 \n\uC798\uBABB\uC774\uC9C0.\""
    - talker: 1
      listener: 1
      face: 3
      text: "\"\uB354 \uC774\uC0C1 \uB108\uC5D0\uAC8C \uB0B4 \uC2DC\uAC04\uC744 \uD5C8\uBE44\uD558\uACE0
        \uC2F6\uC9C0 \uC54A\uC544.\""
  - text: "\uD654\uC81C\uB97C \uB3CC\uB9B0\uB2E4"
    good:
    - talker: 1
      listener: 1
      face: 2
      text: " \"\u2026\uB3C4\uB9DD\uCE58\uB294 \uAC74\uAC00? \uD765\uBBF8\uB86D\uAD70.
        \uC774 \uBBF8\uAD81 \uC18D\uC73C\uB85C \n\uC228\uC5B4\uB4E4\uB824\uB294 \uB108\uC758
        \uC758\uC9C0\uB97C \uC874\uC911\uD558\uC9C0.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uADF8\uB798, \uC624\uB298\uC740 \uC5EC\uAE30\uC11C \uBA48\uCD94\uB3C4\uB85D
        \uD558\uC790.\""
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: " \"\uB098\uC758 \uC9C8\uBB38\uC73C\uB85C\uBD80\uD130 \uB3C4\uB9DD\uCCD0\uB3C4,
        \uB124\uAC00 \uC9CA\uC5B4\uC9C4 \uC6B4\uBA85\uC758 \n\uBB34\uAC8C\uB294 \uBC14\uB00C\uC9C0
        \uC54A\uB294\uB2E4.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uB10C \uACB0\uAD6D \uB0B4 \uB36B\uC5D0\uC11C \uBC97\uC5B4\uB0A0 \uC218
        \uC5C6\uC5B4.\""
