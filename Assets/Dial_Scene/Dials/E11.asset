%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: E11
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uC138 \uC0AC\uB78C\uC774 \uB3D9\uC2DC\uC5D0 \uB0B4 \uC55E\uC73C\uB85C
      \uB2E4\uAC00\uC628\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uD5D0..\u314E\u314E\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uB4DC\uB514\uC5B4.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uBAA8\uB4E0 \uC9C4\uC2E4\uC774 \uD558\uB098\uB85C \uC774\uC5B4\uC9C0\uB294\uAD70.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC5E5?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC6B0\uB9AC \uC14B \uB2E4 \uACE0\uBC31\uD558\uB7EC \uC628\uAC70\uC57C? "
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uC815\uC801\uC774 \uD750\uB978\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uC138 \uC0AC\uB78C\uC758 \uC2DC\uC120\uC774 \uB3D9\uC2DC\uC5D0 \uB098\uB97C
      \uD5A5\uD55C\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: ...
  - talker: -1
    listener: 0
    face: 0
    text: "\uB2E4\uC2DC \uCE68\uBB35."
  - talker: -1
    listener: 0
    face: 0
    text: ...
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uBB50.\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uBA3C\uC800 \uC88B\uC544\uD55C \uC0AC\uB78C\uC774 \uC774\uAE30\uB294
      \uAC70 \uC544\uB0D0?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC5D0?! \uADF8\uB7F0 \uADDC\uCE59\uC774 \uC788\uC5C8\uC5B4?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uD6C4...\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uC124\uB9C8 \uB0B4\uAC00 \uACF5\uB3D9 \uC804\uC120\uC5D0 \uC11C\uAC8C
      \uB420 \uC904\uC774\uC57C.\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uC138 \uC0AC\uB78C\uC740 \uD55C\uB3D9\uC548 \uB9D0\uC5C6\uC774 \uC11C\uB85C\uB97C
      \uBC14\uB77C\uBCF8\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uC774\uC73D\uACE0."
  - talker: -1
    listener: 0
    face: 0
    text: "\uC14B\uC758 \uC2DC\uC120\uC774 \uB2E4\uC2DC \uB0B4\uAC8C \uD5A5\uD588\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uD3C9\uC0DD \uCC45\uC784\uC838.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uB3C4\uB9DD\uAC00\uBA74 \uB05D\uAE4C\uC9C0 \uCAD3\uC544\uAC04\uB2E4?\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uD55C \uC0AC\uB78C\uC758 \uB9C8\uC74C\uC744 \uD488\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4
      \uBC84\uAC70\uC6B4 \uBC95.\""
  - talker: 1
    listener: 0
    face: 0
    text: "\"...\uADF8\uB7F0\uB370 \uB108\uB294 \uC138 \uC0AC\uB78C\uC758 \uB9C8\uC74C\uC744
      \uD488\uACE0\uB3C4 \uBB34\uB108\uC9C0\uC9C0 \uC54A\uC558\uAD70.\""
  - talker: -1
    listener: 0
    face: 0
    text: "...\uC640"
  - talker: -1
    listener: 0
    face: 0
    text: "\uCD95\uD558\uD574\u314B\u314B"
  - talker: -1
    listener: 0
    face: 0
    text: "\uC815\uC0C1\uC801\uC778 \uC5F0\uC560\uB294 \uC774\uBBF8 \uC624\uB798\uC804\uC5D0
      \uD3EC\uAE30\uD55C \uBAA8\uC591\uC774\uC9C0?"
  - talker: -1
    listener: 0
    face: 0
    text: "<BEST END - \uD558\uB818 \uB8E8\uD2B8>"
  choices: []
