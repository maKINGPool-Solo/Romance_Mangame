%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: DIal_3
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: 0
    face: 0
    text: "\uD55C\uB098\uB294 \uBB34\uC5B8\uAC00\uC5D0 \uD479 \uBE60\uC9C4 \uB4EF
      \uC190\uC744 \uBA48\uCD94\uC9C0 \uC54A\uACE0 \uC788\uC5C8\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\"...\uBB50\uD574?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"(\uAE30\uC05C \uC5BC\uAD74\uB85C) \uD6C4\uD6D7~\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC5B4\uB54C? \uC798 \uADF8\uB9AC\uC9C0 \uC54A\uC558\uC5B4?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC774\uBC88\uC5D4 \uC9C4\uC9DC \uC5ED\uC791\uC778 \uAC83 \uAC19\uC544!\""
  choices:
  - text: "\"\uC798 \uADF8\uB838\uB124.\""
    good:
    - talker: 0
      listener: 0
      face: 2
      text: "\"...\uD765.\" "
    - talker: -1
      listener: 0
      face: 2
      text: "\uC560\uC368 \uC544\uBB34\uB807\uC9C0 \uC54A\uC740 \uCC99\uD558\uC9C0\uB9CC
        \uC785\uAF2C\uB9AC\uAC00 \uC544\uC8FC \uC870\uAE08 \uC62C\uB77C\uAC04\uB2E4."
    bad:
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uAC70\uC9D3\uB9D0.\""
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uB300\uCDA9 \uBCF4\uACE0 \uB9D0\uD55C \uAC70\uC796\uC544.\""
    - talker: -1
      listener: 0
      face: 1
      text: "\uC885\uC774\uB97C \uD671 \uAC00\uC838\uAC04\uB2E4."
  - text: "\"\uB098 \uADF8\uB9B0\uAC70\uC57C?\""
    good:
    - talker: 0
      listener: 0
      face: 2
      text: '"...!"'
    - talker: -1
      listener: 0
      face: 2
      text: "\"...\uB204, \uB204\uAC00. \uC544\uB2C8\uAC70\uB4E0?!\""
    - talker: -1
      listener: 0
      face: 2
      text: "\uC7A0\uAE50 \uB2F9\uD669\uD558\uB2E4\uAC00 \uC791\uAC8C \uC911\uC5BC\uAC70\uB9B0\uB2E4."
    - talker: 0
      listener: 0
      face: 2
      text: "\"...\uC870\uAE08 \uB2EE\uAE34 \uD588\uB124.\""
    bad:
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uCE6B.\""
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uC774\uAC8C \uC5B4\uB51C \uBD10\uC11C \uB108\uC57C.\""
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uC81C\uB300\uB85C \uBCF4\uC9C0\uB3C4 \uC54A\uACE0 \uB9C9 \uB9D0\uD558\uB124.\""
  - text: "\"\uC774\uAC8C \uBB50\uC57C?\""
    good:
    - talker: 0
      listener: 0
      face: 2
      text: "\"\"...\uD478\uD761.\"\n"
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uB9DE\uD600\uBCF4\uB77C\uB294 \uAC70\uC600\uB294\uB370.\""
    - talker: -1
      listener: 0
      face: 2
      text: "\uC870\uAE08 \uC2E0\uB09C \uD45C\uC815\uC73C\uB85C \uADF8\uB9BC\uC744
        \uB2E4\uC2DC \uB4E4\uC774\uBBFC\uB2E4."
    - talker: 0
      listener: 0
      face: 2
      text: "\"\uD55C \uBC88 \uB354 \uB9DE\uD600\uBD10.\""
    bad:
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uADF8\uB807\uAC8C \uBABB \uC54C\uC544\uBCF4\uACA0\uC5B4?\""
    - talker: -1
      listener: 0
      face: 1
      text: "\uC7A0\uAE50 \uAD73\uB294\uB2E4."
    - talker: 0
      listener: 0
      face: 1
      text: "\"...\uB410\uC5B4.\""
