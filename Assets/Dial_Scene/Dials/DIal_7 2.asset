%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: DIal_7 2
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: 2
    face: 0
    text: "\uC6B4\uB3D9\uC744 \uB9C8\uCE58\uACE0 \uC628 \uD0D3\uC778\uC9C0, \uBAA9\uC774
      \uB9CE\uC774 \uB9D0\uB790\uB358 \uBAA8\uC591\uC774\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uC7A0\uC2DC \uB4A4."
  - talker: 2
    listener: 2
    face: 0
    text: "\"...\uD478\uD761!!\"\n"
  - talker: -1
    listener: 2
    face: 0
    text: "\uC5F0\uC544\uAC00 \uADF8\uB300\uB85C \uCF5C\uB85D\uAC70\uB9AC\uBA70 \uAE30\uCE68\uC744
      \uD558\uAE30 \uC2DC\uC791\uD588\uB2E4."
  choices:
  - text: "\"\uCC9C\uCC9C\uD788 \uB9C8\uC154.\""
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uD5E4\uD5E4...\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB9E8\uB0A0 \uADF8\uB7EC\uB824\uACE0 \uD558\uB294\uB370, \uC798 \uC548
        \uB418\uB354\uB77C.\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB2E4\uC74C\uBD80\uD134 \uC9C4\uC9DC \uCC9C\uCC9C\uD788 \uB9C8\uC154\uBCFC\uAC8C!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC73C\uC73C...\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC54C\uACE0\uB294 \uC788\uB294\uB370...\"\n"
    - talker: 2
      listener: 2
      face: 1
      text: "\"...\uC794\uC18C\uB9AC \uB4E4\uC73C\uB2C8\uAE4C \uB354 \uBBFC\uB9DD\uD558\uB2E4...\"\n"
  - text: "\"\uBB3C \uC904\uAE4C?\""
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC5C9!\""
    - talker: -1
      listener: 2
      face: 2
      text: "(\uC7AC\uBE68\uB9AC \uBB3C\uC744 \uBC1B\uC544 \uBC8C\uCEE5 \uB9C8\uC2E0\uB2E4.)"
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uD6C4\uC6B0... \uC0B4\uC558\uB2E4! \uACE0\uB9C8\uC6CC!\""
    bad:
    - talker: 2
      listener: 2
      face: 0
      text: "\"\uBB3C...!\""
    - talker: -1
      listener: 2
      face: 0
      text: "(\uAE09\uD558\uAC8C \uBC1B\uC73C\uB824\uB2E4 \uCEF5\uC744 \uB193\uCE5C\uB2E4.)"
    - talker: -1
      listener: 2
      face: 1
      text: "\"\uC557!!\""
    - talker: -1
      listener: 2
      face: 1
      text: "\"...\uBBF8\uC548.\""
    - talker: 2
      listener: 2
      face: 1
      text: "\uC5F0\uC544\uB294 \uBC14\uB2E5\uC5D0 \uC5CE\uC9C8\uB7EC\uC9C4 \uBB3C\uC744
        \uBA4D\uD558\uB2C8 \uBC14\uB77C\uBCF8\uB2E4."
  - text: "\"\uAD1C\uCC2E\uC544?\""
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC751! \uAD1C\uCC2E\uC544!\""
    - talker: 2
      listener: 2
      face: 2
      text: "(\uC5C4\uC9C0\uB97C \uCE58\uCF1C\uC138\uC6B4\uB2E4.)"
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC774\uB7F0 \uC801\uC774 \uD55C \uB450\uBC88\uC774 \uC544\uB2C8\uC5B4\uC11C\u314E\u314E\u314E\" "
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB10C \uBB34\uC2A8 \uC74C\uB8CC \uB9C8\uC2DC\uB294 \uC911\uC774\uC57C?\" "
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC544, \uC544\uB2C8...\""
    - talker: 2
      listener: 2
      face: 1
      text: "(\uCF5C\uB85D\uAC70\uB9AC\uBA70 \uC190\uC0AC\uB798\uB97C \uCE5C\uB2E4.)"
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uBBF8\uC548... \uB098 \uBB3C\uBD80\uD130 \uC880 \uCC3E\uACE0 \uC62C\uAC8C...!\""
    - talker: -1
      listener: 2
      face: 1
      text: "\uB354 \uB9D0\uC744 \uBD99\uC77C \uD2C8\uB3C4 \uC5C6\uC774, \uC5F0\uC544\uB294
        \uD5C8\uB465\uC9C0\uB465 \uC790\uB9AC\uB97C \uB5A0\uB0AC\uB2E4."
