%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: DIal_4 1
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: 1
    face: 0
    text: "\uB179\uC2A4\uB294 \uBE57\uC790\uB8E8\uB97C \uB4E4\uACE0 \uD55C \uCE58\uC758
      \uB9DD\uC124\uC784\uB3C4 \uC5C6\uC774 \uD5C8\uACF5\uC744 \uBCA0\uC5B4\uB0B8\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "\uC8FC\uBCC0\uC5D0\uB294 \uC544\uBB34\uAC83\uB3C4 \uC5C6\uC9C0\uB9CC,
      \uB179\uC2A4\uC758 \uB208\uC5D0\uB294 \uBB34\uC5B8\uAC00 \uBCF4\uC774\uB294
      \uBAA8\uC591\uC774\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "\uC7A0\uC2DC \uD6C4, \uB2E4\uC2DC \uD55C \uBC88 \uAC19\uC740 \uB3D9\uC791\uC774
      \uC774\uC5B4\uC9C4\uB2E4.\n"
  - talker: -1
    listener: 1
    face: 0
    text: "\"...\uBB50 \uD574?\""
  - talker: 1
    listener: 1
    face: 0
    text: "\"...\uB9E4\uC77C \uAC08\uACE0\uB2E6\uC9C0 \uC54A\uC73C\uBA74..\uAC80\uB3C4,
      \uC0AC\uB78C\uB3C4 \uBB34\uB38C\uC9C0\uAC70\uB4E0.\""
  choices:
  - text: "\"\uBA4B\uC788\uB124.\""
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "(\uC528\uC775 \uC6C3\uC73C\uBA70) \"...\uC548\uBAA9\uC740 \uC788\uAD70.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uC5B4\uB54C.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uB108\uB3C4 \uB098\uC640 \uD568\uAED8 \uC218\uB828\uD558\uC9C0
        \uC54A\uACA0\uB098?\""
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: '"..."'
    - talker: -1
      listener: 1
      face: 1
      text: "\uC7A0\uAE50 \uBE57\uC790\uB8E8\uB97C \uB0B4\uB824\uB193\uB294\uAC00
        \uC2F6\uB354\uB2C8, \uC774\uB0B4 \uB2E4\uC2DC \uB4E4\uC5B4 \uC62C\uB9B0\uB2E4.\n"
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC6B0\uC2B5\uAC8C \uB4E4\uB838\uB098.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC774\uD574\uD558\uC9C0 \uBABB\uD55C\uB2E4\uBA74, \uADF8\uAC78\uB85C
        \uB410\uB2E4.\""
    - talker: -1
      listener: 1
      face: 1
      text: "\uC544\uBB34\uB798\uB3C4 \uC624\uD574\uD55C \uAC83 \uAC19\uB2E4."
  - text: "\"\uB098\uB3C4 \uD55C\uBC88 \uD574\uBD10\uB3C4 \uB3FC?\""
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uC88B\uC544.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uD558\uC9C0\uB9CC \uBA85\uC2EC\uD574.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uC774 \uAC80\uC740, \uC8FC\uC778\uC744 \uC27D\uAC8C \uC778\uC815\uD558\uC9C0
        \uC54A\uB294\uB2E4.\""
    - talker: -1
      listener: 1
      face: 2
      text: "(\uBE57\uC790\uB8E8\uB97C \uC9C4\uC9C0\uD558\uAC8C \uAC74\uB128\uB2E4.)"
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uD749\uB0B4\uB9CC\uC73C\uB85C\uB294 \uAC80\uC744 \uC958 \uC218 \uC5C6\uC5B4.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC81C\uB300\uB85C \uBCF4\uC9C0\uB3C4 \uC54A\uACE0 \uB9C9 \uB9D0\uD558\uB124.\""
  - text: "\"\uC218\uB828 \uADF8\uB9CC\uD558\uACE0 \uCCAD\uC18C\uD558\uB294\uAC74
      \uC5B4\uB54C?\""
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "\uB179\uC2A4\uB294 \uBE57\uC790\uB8E8\uB97C \uD55C \uBC88 \uB0B4\uB824\uB2E4\uBCF8\uB2E4."
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uADF8\uAC83\uB3C4 \uB098\uC058\uC9C4 \uC54A\uAD70.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uD759\uBA3C\uC9C0\uB97C \uCE58\uC6B0\uB4E0, ...\uC545\uC744 \uBCA0\uC5B4\uB0B4\uB4E0.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uB458 \uB2E4 \uC138\uACC4\uB97C \uC815\uB3C8\uD558\uB294 \uC77C\uC774\uC9C0.\"(\uD76C\uBBF8\uD558\uAC8C
        \uC6C3\uB294\uB2E4.)"
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uCC9C\uBC15\uD55C \uBC1C\uC0C1\uC774\uAD70.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"\uC774\uAC74 \uBE57\uC790\uB8E8\uAC00 \uC544\uB2C8\uB2E4.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"......\uAC80\uC774\uB2E4.\""
    - talker: -1
      listener: 1
      face: 1
      text: "\uB179\uC2A4\uB294 \uAD1C\uD788 \uD5DB\uAE30\uCE68\uC744 \uD55C \uBC88
        \uD558\uACE0\uB294, \uC544\uBB34 \uC77C\uB3C4 \uC5C6\uC5C8\uB2E4\uB294 \uB4EF
        \uB2E4\uB978 \uACF3\uC73C\uB85C \uAC78\uC5B4\uAC04\uB2E4."
