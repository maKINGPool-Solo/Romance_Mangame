%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: Dial_0 2
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\u201C\uD30C\uBC15.\u201D"
  - talker: -1
    listener: -1
    face: 0
    text: "\uC544\uC8FC \uC791\uC740 \uC18C\uB9AC\uC600\uB2E4."
  - talker: -1
    listener: -1
    face: 0
    text: "\uD558\uC9C0\uB9CC \uC774\uC0C1\uD558\uAC8C\uB3C4, \uADF8 \uC21C\uAC04
      \uC8FC\uBCC0\uC774 \uC870\uC6A9\uD574\uC9C4 \uAC83\uCC98\uB7FC \uB290\uAEF4\uC84C\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uC2DC\uC120\uC744 \uB3CC\uB9AC\uC790, \uBC30\uC5F0\uC544\uAC00 \uBB34\uC5B8\uAC00\uB97C
      \uB5A8\uC5B4\uB728\uB9B0 \uCC44 \uBC14\uB2E5\uC744 \uB354\uB4EC\uACE0 \uC788\uC5C8\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uB2E4\uAC00\uAC00\uB824\uB358 \uC21C\uAC04\u2014"
  - talker: -1
    listener: 2
    face: 0
    text: "\uD22D."
  - talker: -1
    listener: 2
    face: 0
    text: "\uC2DC\uC120\uC774 \uB9DE\uBD80\uB52A\uD78C\uB2E4."
  choices:
  - text: "\uC8FC\uC6CC\uC900\uB2E4."
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC544! \uACE0\uB9C8\uC6CC! \uC73C\uD558\uD558, \uB0B4\uAC00 \uB610
        \uB35C\uB801\uB314\uC9C0? \n\uB108 \uC9C4\uC9DC \uBBFC\uCCA9\uD558\uB2E4!\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC6B4\uB3D9\uBD80\uC778 \uB098\uBCF4\uB2E4 \uB354 \uBE60\uB978 \uAC83
        \uAC19\uC544. \uB355\uBD84\uC5D0 \uC0B4\uC558\uB2E4!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC5B4? \uC544, \uC751\u2026 \uACE0\uB9C8\uC6CC..?\""
    - talker: 2
      listener: 2
      face: 1
      text: "(\uC8FC\uBCC0\uC744 \uB450\uB9AC\uBC88\uAC70\uB9B0\uB2E4) \u2026\"\uB09C
        \uC774\uC81C \uAC08\uAC8C..\""
  - text: "\uBC14\uB77C\uBCF4\uAE30\uB9CC \uD55C\uB2E4."
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "(\uBA40\uB6B1\uD788 \uCCD0\uB2E4\uBCF4\uBA70) \"\uC65C \uADF8\uB807\uAC8C
        \uBE64\uD788 \uBD10? \u2026\uC5B4, \n\uC5BC\uAD74\uC774 \uBE68\uAC1C\uC9C4
        \uAC70 \uAC19\uAE30\uB3C4 \uD558\uACE0?\""
    - talker: 2
      listener: 2
      face: 2
      text: "(\uC6C3\uC74C) \"\uC7A5\uB09C\uCE58\uC9C0 \uB9C8, \uB098 \uC9C4\uC9DC
        \uC124\uB808\uBC84\uB9AC\uC796\uC544!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\u2026\uBB50\uC57C, \uC0AC\uB78C \uBD88\uD3B8\uD558\uAC8C! \uBA4D\uD558\uB2C8
        \uCCD0\uB2E4\uB9CC \uBCF4\uC9C0 \n\uB9D0\uACE0 \uC880 \uB3C4\uC640\uC8FC\uBA74
        \uC5B4\uB514\uAC00 \uB367\uB098?\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uC644\uC804 \uB098\uC0AC \uD480\uB9B0 \uC0AC\uB78C\uCC98\uB7FC \uAD74\uC9C0
        \uB9C8!\""
  - text: "\"\uBC14\uB2E5\uC5D0 \uBB50 \uB300\uB2E8\uD55C \uAC70\uB77C\uB3C4 \uC788\uC5B4?
      \uB098 \uB9D0\uACE0.\" (\uD50C\uB7EC\uD305)"
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "(\uB208\uC744 \uB3D9\uADF8\uB797\uAC8C \uB728\uB2E4\uAC00 \uC5BC\uAD74\uC774
        \uD655 \uB2EC\uC544\uC624\uB978\uB2E4) \"\u2026\uC5B4? \uBB50\uC57C, \uC9C4\uC9DC\u2026
        \uC0AC\uB78C \uB180\uB9AC\uC9C0 \uB9C8!\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uB098 \uC9C0\uAE08 \uC9C4\uC2EC\uC73C\uB85C \uB450\uADFC\uAC70\uB838\uB2E4\uACE0!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uBB50..\uBB50?\u2026\uBB50\uB77C\uB294 \uAC70\uC57C? \uC73D, \uB2ED\uC0B4
        \uB3CB\uC544!\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uAC11\uC790\uAE30 \uC65C \uADF8\uB798? \uB2F9\uD669\uC2A4\uB7FD\uC796\uC544!\""
