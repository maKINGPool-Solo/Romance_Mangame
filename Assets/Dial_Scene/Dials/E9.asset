  dials:
  - talker: -1
    listener: -1
    face: 0
    text: "\uD55C\uB098\uC640 \uC5F0\uC544\uAC00 \uB3D9\uC2DC\uC5D0 \uB0B4 \uC55E\uC73C\uB85C
      \uB2E4\uAC00\uC628\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uC5B4?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uC5F0\uC544?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC557! \uD55C\uB098?\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"...\uC65C \uC5EC\uAE30 \uC788\uC5B4?\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC124\uB9C8...\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC7A0\uAE50!\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC6B0\uB9AC \uB458 \uB2E4 \uACE0\uBC31\uD558\uB7EC \uC628 \uAC70\uC57C?!\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uC7A0\uC2DC \uC815\uC801\uC774 \uD750\uB978\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "\uD55C\uB098\uC640 \uC5F0\uC544\uAC00 \uB3D9\uC2DC\uC5D0 \uB098\uB97C
      \uBC14\uB77C\uBCF8\uB2E4."
  - talker: 0
    listener: 0
    face: 0
    text: "\"...\uD765.\""
  - talker: 0
    listener: 0
    face: 0
    text: "\"\uC774\uBC88\uB9CC\uD07C\uC740 \uC548 \uC838.\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uC88B\uC544!\""
  - talker: 2
    listener: 0
    face: 0
    text: "\"\uADF8\uB7FC \uC815\uC815\uB2F9\uB2F9\uD558\uAC8C \uC2B9\uBD80\uB2E4!\""
  - talker: -1
    listener: 0
    face: 0
    text: "\uB458\uC740 \uC11C\uB85C\uB97C \uB9C8\uC8FC \uBCF4\uBA70 \uC529 \uC6C3\uC5C8\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "...\uC660\uC9C0 \uC55E\uC73C\uB85C\uB3C4 \uB9E4\uC77C \uC2DC\uB04C\uBC85\uC801\uD560
      \uAC83 \uAC19\uB2E4."
  - talker: -1
    listener: 0
    face: 0
    text: "<GOOD END - \uCD5C\uACE0\uC758 \uB77C\uC774\uBC8C>"
  choices: []
