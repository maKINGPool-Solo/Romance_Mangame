%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: Dial_1 2
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: 0
    listener: 2
    face: 0
    text: "\u201C\uADF8\uB54C \uADF8\uAC70\u2026 \uAE30\uC5B5\uD574?\u201D"
  - talker: -1
    listener: 2
    face: 0
    text: "\uC5F0\uC544\uAC00 \uC544\uBB34\uB807\uC9C0 \uC54A\uAC8C \uB9D0\uD55C\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uD558\uC9C0\uB9CC \uACF5\uAE30\uAC00 \uC870\uAE08 \uC774\uC0C1\uD558\uB2E4."
  - talker: -1
    listener: 2
    face: 0
    text: "\uBB34\uC2A8 \uC598\uAE30\uC778\uC9C0 \uBAA8\uB974\uACA0\uB2E4."
  choices:
  - text: "\uAE30\uC5B5\uD558\uB294 \uCC99 \uD55C\uB2E4."
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC815\uB9D0? \uAE30\uC5B5\uD558\uACE0 \uC788\uC5C8\uC5B4?\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC640, \uB098 \uD63C\uC790 \uC553\uB358 \uAC8C \uC544\uB2C8\uC5C8\uAD6C\uB098!
        \uB2E4\uD589\uC774\uB2E4, \n\uC774\uC81C\uC57C \uB9C8\uC74C\uC774 \uC880
        \uB193\uC774\uB124!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\u2026\uC5B4? \uC815\uB9D0 \uAE30\uC5B5\uB098? \uADFC\uB370 \uC65C
        \uBAA9\uC18C\uB9AC\uAC00 \uADF8\uB807\uAC8C \uB5A8\uB824?\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uAC70\uC9D3\uB9D0\uD558\uB294 \uAC70 \uB2E4 \uD2F0 \uB098\uAC70\uB4E0?
        \n\uC9C4\uC9DC, \uB10C \uC65C \uC774\uB7F4 \uB54C\uB9CC \uB454\uD574!\""
  - text: "\uC194\uC9C1\uD558\uAC8C \uBAA8\uB978\uB2E4\uACE0 \uD55C\uB2E4"
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC544\u2026 \uADF8\uB7AC\uAD6C\uB098. \uC194\uC9C1\uD558\uAC8C \uB9D0\uD574\uC918\uC11C
        \uACE0\uB9C8\uC6CC!"
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC0AC\uC2E4 \uB098\uB3C4 \uB108\uBB34 \uC624\uB798\uB3FC\uC11C \uB108\uD55C\uD14C
        \uBB3C\uC5B4\uBCF4\uB824\uACE0 \n\uD55C \uAC70\uC600\uC5B4. \uB2E4\uC2DC
        \uCC28\uADFC\uCC28\uADFC \uC774\uC57C\uAE30\uD574 \uBCFC\uAE4C?\""
    bad:
    - talker: 2
      listener: 2
      face: 3
      text: "\"\uC5D0\uC5D1? \uC9C4\uC9DC \uBAB0\uB77C? \n\uADF8\uB0A0 \uC9C4\uC9DC
        \uC911\uC694\uD55C \uC77C\uC774 \uC788\uC5C8\uB294\uB370\u2026\""
    - talker: 2
      listener: 2
      face: 3
      text: "\"\uD558\uAE34, \uB124\uAC00 \uAE30\uC5B5\uD560 \uB9AC\uAC00 \uC5C6\uC9C0.\"
        \n(\uC2E4\uB9DD\uD55C \uB4EF \uACE0\uAC1C\uB97C \uB5A8\uAD70\uB2E4)"
  - text: "\uD654\uC81C\uB97C \uB3CC\uB9B0\uB2E4"
    good:
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC5D0.. \uC5B4.. \uC6B0\uB9AC\uAC00 \uBC29\uAE08\uAE4C\uC9C0 \uBB34\uC2A8
        \uC560\uAE30 \uD558\uACE0 \n\uC788\uC5C8\uC9C0?\""
    - talker: 2
      listener: 2
      face: 2
      text: "\"\uC544 \uBAB0\uB77C! \uC6B0\uB9AC \uC800\uAE30 \uAD6C\uACBD\uD558\uB7EC
        \uAC00\uC790!\""
    bad:
    - talker: 2
      listener: 2
      face: 1
      text: "\"\u2026\uC5B4? \uAC11\uC790\uAE30 \uC65C \uB534\uC18C\uB9AC\uC57C?
        \uB098 \uC9C0\uAE08 \uB418\uAC8C \uC911\uC694\uD55C\n \uC598\uAE30 \uD558\uB824\uACE0
        \uD588\uB294\uB370\u2026\""
    - talker: 2
      listener: 2
      face: 1
      text: "\"\uB108 \uC9C4\uC9DC \uB098\uC0AC \uD480\uB9B0 \uAC70 \uC544\uB2C8\uC57C?\""
