%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 644aedb8eb5027142810577af515b913, type: 3}
  m_Name: DIal_5 2
  m_EditorClassIdentifier: Assembly-CSharp::Dial
  dials:
  - talker: -1
    listener: 1
    face: 0
    text: "\uB179\uC2A4\uB294 \uCC28\uBD84\uD788 \uCEE4\uD53C\uB97C \uB9C8\uC2DC\uACE0
      \uC788\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "...\uCEF5\uC5D0 \uB2F4\uACA8\uC9C4 \uC561\uCCB4\uB294 \uC22F\uBCF4\uB2E4\uB3C4
      \uB354 \uAC80\uACE0 \uD0C1\uD574 \uBCF4\uC778\uB2E4."
  - talker: -1
    listener: 1
    face: 0
    text: "\uB179\uC2A4\uAC00 \uC870\uC6A9\uD788 \uCEF5\uC744 \uB0B4\uB824\uB193\uB294\uB2E4.\n"
  - talker: -1
    listener: 1
    face: 0
    text: "\"...\uADF8\uAC70 \uB9DB\uC788\uC5B4?\""
  - talker: -1
    listener: 1
    face: 0
    text: "\uB179\uC2A4\uB294 \uCEF5\uC744 \uD55C \uBC88 \uB0B4\uB824\uB2E4\uBCF4\uB354\uB2C8,
      \uD53C\uC2DD \uC6C3\uB294\uB2E4."
  - talker: 1
    listener: 1
    face: 0
    text: "\"...\uC4F4\uB9DB\uC740 \uC9C4\uC2E4\uC744 \uAC10\uCD94\uC9C0 \uC54A\uB294\uB2E4.\""
  - talker: 1
    listener: 1
    face: 0
    text: "\"...\uB2EC\uCF64\uD568\uC740, \uB108\uBB34 \uC27D\uAC8C \uC0AC\uB78C\uC744
      \uBC29\uC2EC\uD558\uAC8C \uB9CC\uB4E4\uC9C0.\""
  choices:
  - text: "\"...\uC124\uD0D5 \uC904\uAE4C?\""
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "(\uC124\uD0D5\uC744 \uBC1B\uC73C\uB824\uB2E4\uAC00 \uB9CC\uB2E4) \"...\uC0AC\uC591\uD558\uC9C0.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uD558\uC9C0\uB9CC \uC81C\uC548\uC740 \uACE0\uB9D9\uAD70.\"\n"
    - talker: 1
      listener: 1
      face: 2
      text: "\"\uB098\uB294 \uB0B4 \uBC29\uC2DD\uC774 \uC88B\uC544.\""
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC124\uD0D5?\""
    - talker: -1
      listener: 1
      face: 1
      text: "\uD53C\uC2DD \uC6C3\uB294\uB2E4.\n"
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC124\uD0D5\uC744 \uB123\uB294 \uC21C\uAC04.\uADF8\uAC74 \uC774\uBBF8
        \uCEE4\uD53C\uAC00 \uC544\uB2C8\uC57C.\""
  - text: "\"\uB098\uB3C4 \uD55C \uBAA8\uAE08 \uBA39\uC744\uB798.\""
    good:
    - talker: -1
      listener: 1
      face: 2
      text: "\uB179\uC2A4\uB294 \uC7A0\uC2DC \uB108\uB97C \uBC14\uB77C\uBCF4\uB2E4
        \uCEF5\uC744 \uB0B4\uBBFC\uB2E4."
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uD6C4\uD68C\uD558\uC9C0 \uB9C8.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uC774\uAC74 \uC544\uBB34\uB098 \uACAC\uB514\uB294 \uB9DB\uC774
        \uC544\uB2C8\uB2C8\uAE4C.\""
    bad:
    - talker: -1
      listener: 1
      face: 1
      text: "\uB179\uC2A4\uAC00 \uCEF5\uC744 \uC0B4\uC9DD \uB4A4\uB85C \uBE80\uB2E4."
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC544\uC9C1\uC740 \uC548 \uB41C\uB2E4.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC774 \uB9DB\uC744 \uC774\uD574\uD558\uB824\uBA74, \uC870\uAE08
        \uB354 \uC2DC\uAC04\uC774 \uD544\uC694\uD574.\""
  - text: "\"\uB09C \uAC1C\uC778\uC801\uC73C\uB85C \uB77C\uB5BC\uAC00 \uB354 \uC88B\uC544.\""
    good:
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uCDE8\uD5A5\uC744 \uBD80\uC815\uD560 \uC0DD\uAC01\uC740 \uC5C6\uB2E4.\""
    - talker: 1
      listener: 1
      face: 2
      text: "\"...\uAC01\uC790\uC758 \uC794\uC5D0\uB294 \uAC01\uC790\uC758 \uC774\uC720\uAC00
        \uB2F4\uAE30\uB294 \uBC95\uC774\uC9C0.\""
    bad:
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uB77C\uB5BC.\""
    - talker: -1
      listener: 1
      face: 1
      text: "\uC7A0\uC2DC \uCE68\uBB35."
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC4F4\uB9DB\uC744 \uAC10\uB2F9\uD558\uC9C0 \uBABB\uD558\uBA74\uC11C,
        \uCEE4\uD53C\uB97C \uB17C\uD558\uB294 \uAC74\uAC00.\""
    - talker: 1
      listener: 1
      face: 1
      text: "\"...\uC5B4\uB9B0\uC560 \uC785\uB9DB\uC774\uAD70.\""
