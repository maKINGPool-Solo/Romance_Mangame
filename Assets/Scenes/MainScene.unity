--- !u!114 &185672103
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 185672102}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b8c357e9bb0a37e43968c60d2fe3c3fe, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::MainMonologueManager
  monologuePanel: {fileID: 185672102}
  monologueText: {fileID: 185672101}
  lines:
  - "\uCEA0\uD37C\uC2A4\uB294 \uB298 \uADF8\uB807\uB4EF \uD65C\uAE30\uAC00 \uB118\uCE5C\uB2E4.
    \uC624\uAC00\uB294 \uC218\uB9CE\uC740 \uC0AC\uB78C\uB4E4, \uBC14\uC058\uAC8C
    \uD769\uC5B4\uC9C0\uB294 \uBC1C\uC18C\uB9AC\uB4E4.\n\uD558\uC9C0\uB9CC \uB0B4
    \uC2DC\uC120\uC740 \uC5B8\uC81C\uB098 \uADF8 \uC0AC\uB78C\uD55C\uD14C \uAC00\uAC8C
    \uB41C\uB2E4.."
  - "\uADF8 \uC0AC\uB78C\uACFC \uAC00\uB054 \uB300\uD654\uB3C4 \uB098\uB204\uACE0,
    \uC6C3\uACE0 \uB5A0\uB4E4\uAE30\uB3C4 \uD588\uC9C0\uB9CC \uB531 \uAC70\uAE30\uAE4C\uC9C0.\n\uC6B0\uB9AC\uC758
    \uAD00\uACC4\uB294 \uB298 '\uCE5C\uAD6C'\uB77C\uB294 \uC6B8\uD0C0\uB9AC \uC548\uC5D0
    \uAC07\uD600 \uC788\uC5C8\uB2E4."
  - "'....\uC815\uB9D0 \uC774\uB807\uAC8C \uB05D\uB0BC\uAC70\uC57C?? \uC62C\uD574\uB3C4
    \uB2E4\uC2DC \uBAA8\uC194\uB85C \uC0B4\uC544\uAC08 \uAC70\uB0D0\uACE0! '"
  - "'\uC544\uB0D0! \uC774\uBC88\uC5D0\uC57C\uB9D0\uB85C \uB09C \uC6A9\uAE30\uB97C
    \uB0B4\uACA0\uC5B4! \uADF8\uB798! \uD55C\uBC88 3\uC77C \uB4A4\uC5D0 \uACE0\uBC31\uD55C\uB2E4\uB294
    \uAC01\uC624\uB85C \uB300\uD654\uB97C \uB098\uB204\uB294\uAC70\uC57C!'"
